{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "items": [
    {
      "name": "next-prettier",
      "type": "registry:item",
      "devDependencies": [
        "prettier@^3.0.0",
        "prettier-plugin-tailwindcss@^0.x.x"
      ],
      "files": [
        {
          "path": "./src/next-prettier/.prettierrc",
          "type": "registry:item",
          "target": "~/.prettierrc"
        },
        {
          "path": "./src/next-prettier/.prettierignore",
          "type": "registry:item",
          "target": "~/.prettierignore"
        }
      ]
    },
    {
      "name": "next-env",
      "type": "registry:item",
      "files": [
        {
          "path": "./src/next-env/utils.ts",
          "type": "registry:item",
          "target": "~/utils/env.ts"
        }
      ]
    },
    {
      "name": "next-internationalization",
      "type": "registry:item",
      "dependencies": ["next-international@^1.0.0"],
      "files": [
        {
          "path": "./src/next-internationalization/app-[locale]-layout.tsx",
          "type": "registry:item",
          "target": "~/app/[locale]/layout.tsx"
        },
        {
          "path": "./src/next-internationalization/locales-client.ts",
          "type": "registry:item",
          "target": "~/locales/client.ts"
        },
        {
          "path": "./src/next-internationalization/locales-server.ts",
          "type": "registry:item",
          "target": "~/locales/server.ts"
        },
        {
          "path": "./src/next-internationalization/locales-en.ts",
          "type": "registry:item",
          "target": "~/locales/en.ts"
        },
        {
          "path": "./src/next-internationalization/locales-ja.ts",
          "type": "registry:item",
          "target": "~/locales/ja.ts"
        },
        {
          "path": "./src/next-internationalization/proxy.ts",
          "type": "registry:item",
          "target": "~/proxy.ts"
        }
      ]
    },
    {
      "name": "next-storyblok",
      "type": "registry:item",
      "dependencies": ["@storyblok/react@~5.2.0"],
      "devDependencies": ["storyblok@~4.0.0"],
      "files": [
        {
          "path": "./src/next-storyblok/components-storyblok-context.tsx",
          "type": "registry:item",
          "target": "~/components/storyblok-context.tsx"
        },
        {
          "path": "./src/next-storyblok/components-storyblok-provider.tsx",
          "type": "registry:item",
          "target": "~/components/storyblok-provider.tsx"
        },
        {
          "path": "./src/next-storyblok/components-storyblok-richtext.tsx",
          "type": "registry:item",
          "target": "~/components/storyblok-richtext.tsx"
        },
        {
          "path": "./src/next-storyblok/lib.ts",
          "type": "registry:item",
          "target": "~/lib/storyblok.ts"
        },
        {
          "path": "./src/next-storyblok/utils.ts",
          "type": "registry:item",
          "target": "~/utils/storyblok.ts"
        }
      ]
    }
  ]
}
